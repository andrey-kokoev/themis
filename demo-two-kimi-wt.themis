module "two_kimi" {
  workspace "main" {
    pipe { from: left, to: right }
    pipe { from: right, to: left }

    tab "conversation" in local {
      pane left { command "export PATH=\$HOME/.local/bin:\$PATH; echo 'Hello, lets collaborate.'; /home/andrey/.local/bin/kimi" }
      pane right { command "export PATH=\$HOME/.local/bin:\$PATH; /home/andrey/.local/bin/kimi" }
    }
  }
}
